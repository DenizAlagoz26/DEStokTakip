# ===================================================================
#  Java / Maven Projeleri için Genel .gitignore Dosyası
# ===================================================================

# Derleme çıktıları ve log dosyaları
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar.md5
.mvn/wrapper/maven-wrapper.jar.sha1

# Log dosyaları
*.log
hs_err_pid*

# Maven sarmalayıcı (wrapper) JAR dosyasını İSTİSNA olarak tut.
# Bu, başkalarının Maven kurmadan projeyi derlemesini sağlar.
!/.mvn/wrapper/maven-wrapper.jar

# ===================================================================
#  IDE'ye Özel Ayar Dosyaları
# ===================================================================

### IntelliJ IDEA ###
# Bu klasör kullanıcıya özel ayarları (pencere konumu, geçmiş vb.) içerir.
# Paylaşılması proje açılışında hatalara neden olur.
.idea/

# IntelliJ'nin eski veya farklı proje yapılarında kullandığı dosyalar.
*.iml
*.ipr
*.iws
out/

### VS Code ###
.vscode/

### Eclipse ###
.classpath
.project
.settings/
.apt_generated
.factorypath
.springBeans
.sts4-cache

### NetBeans ###
nbproject/private/
build/
nbbuild/
dist/
nbdist/
.nb-gradle/

# ===================================================================
#  İşletim Sistemine Özel Dosyalar
# ===================================================================

### Mac OS ###
.DS_Store
.AppleDouble
.LSOverride

### Windows ###
Thumbs.db
ehthumbs.db
Desktop.ini